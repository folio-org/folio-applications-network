doctype html
html(lang="en")
  head
    title Network
    script(type="text/javascript" src="https://unpkg.com/3d-force-graph")
    style(type="text/css").
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background: #0a0a0f;
        font-family: sans-serif;
        overflow: hidden;
      }

      #main {
        display: flex;
        width: 100vw;
        height: 100vh;
      }

      #apps_network {
        flex: 1;
      }

      #legend {
        width: 180px;
        height: 100vh;
        border-right: 1px solid #2a2a3a;
        padding: 12px 10px;
        background: #111118;
        color: #ccc;
        overflow-y: auto;
        z-index: 10;
      }

      #legend h2 {
        color: #eee;
        font-size: 1rem;
        margin-bottom: 10px;
      }

      #legend .legend-list {
        padding: 0;
        list-style: none;
      }

      #legend .legend-list .legend-section {
        font-weight: 600;
        margin: 10px 0 4px;
        color: #888;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      #legend .legend-color {
        width: 10px;
        height: 10px;
        display: inline-block;
        vertical-align: middle;
        border-radius: 50%;
      }

      #legend .legend-color.valid {
        background: #97c2fc;
        border: 1px solid #2b7ce8;
      }

      #legend .legend-color.invalid {
        background: red;
        border: 1px solid red;
      }

      #legend .legend-color.planned {
        background: #888;
        border: 1px solid #555;
      }

      #legend .legend-element {
        display: inline-block;
        vertical-align: middle;
      }

      #legend .legend-element.application {
        width: 20px;
        height: 10px;
        border-radius: 50%;
        background: #97c2fc;
        border: 1px solid #2b7ce8;
      }

      #legend .label {
        display: inline-block;
        vertical-align: middle;
        margin-left: 5px;
        font-size: 0.85rem;
      }
  body
    div#main
      div#legend
        h2 Legend
        ul.legend-list
          li.legend-section Color
          li
            span.legend-color.valid
            span.label Valid

          li
            span.legend-color.invalid
            span.label Invalid

          li
            span.legend-color.planned
            span.label Planned

          li.legend-section Element

          li
            span.legend-element.application
            span.label Application

          li
            span.legend-element.required &#8594;
            span.label Required dependency

          li
            span.legend-element.optional &#8674;
            span.label Optional dependency
      div#apps_network

    script(type="text/javascript").
      var rawNodes = !{JSON.stringify(apps)};
      var rawLinks = !{JSON.stringify(dependencies)};

      var degreeMap = {};
      rawNodes.forEach(function(n) { degreeMap[n.id] = 0; });
      rawLinks.forEach(function(d) {
        if (degreeMap[d.from] !== undefined) degreeMap[d.from]++;
        if (degreeMap[d.to] !== undefined) degreeMap[d.to]++;
      });
      var maxDegree = Math.max.apply(null, Object.values(degreeMap).concat([1]));

      var nodes = rawNodes.map(function(n) {
        return {
          id: n.id,
          name: n.label,
          color: (n.color && n.color.background) ? n.color.background : '#97c2fc',
          degree: degreeMap[n.id] || 0,
        };
      });

      var links = rawLinks.map(function(d) {
        return {
          source: d.from,
          target: d.to,
          color: (d.color && d.color.color) ? d.color.color : '#4a6fa5',
          dashes: d.dashes,
        };
      });

      var container = document.getElementById('apps_network');

      var Graph = ForceGraph3D()(container)
        .graphData({ nodes: nodes, links: links })
        .nodeLabel(null)
        .nodeColor(function(node) { return node.color; })
        .nodeVal(function(node) { return Math.max(2, 2 + (node.degree / maxDegree) * 18); })
        .linkColor(function(link) { return link.color; })
        .linkOpacity(0.5)
        .linkDirectionalArrowLength(4)
        .linkDirectionalArrowRelPos(1)
        .linkDirectionalParticles(function(link) { return link.dashes ? 0 : 1; })
        .linkDirectionalParticleSpeed(0.004)
        .backgroundColor('#0a0a0f')
        .width(window.innerWidth - 180)
        .height(window.innerHeight);

      function makeRadialForce(radiusFn) {
        var fnodes, str = 0.15;
        function force(alpha) {
          fnodes.forEach(function(d) {
            var r = radiusFn(d);
            var x = (d.x !== undefined && d.x !== 0) ? d.x : 0.001;
            var y = d.y || 0;
            var z = d.z || 0;
            var dist = Math.sqrt(x * x + y * y + z * z) || 0.001;
            var k = (dist - r) / dist * str * alpha;
            d.vx -= x * k;
            d.vy -= y * k;
            d.vz -= z * k;
          });
        }
        force.initialize = function(n) { fnodes = n; };
        return force;
      }

      Graph.d3Force('radial', makeRadialForce(function(node) {
        return 280 * (1 - node.degree / (maxDegree + 1));
      }));
      Graph.d3Force('charge').strength(-120);

      var labelCanvas = document.createElement('canvas');
      labelCanvas.style.cssText = 'position:absolute;top:0;left:0;pointer-events:none;';
      container.style.position = 'relative';
      container.appendChild(labelCanvas);
      var ctx = labelCanvas.getContext('2d');

      function renderLabels() {
        var w = container.clientWidth, h = container.clientHeight;
        labelCanvas.width = w;
        labelCanvas.height = h;
        ctx.clearRect(0, 0, w, h);
        ctx.font = '10px "Times New Roman", serif';
        ctx.lineWidth = 3;
        ctx.strokeStyle = 'rgba(0,0,0,0.8)';
        ctx.fillStyle = '#ffffff';
        Graph.graphData().nodes.forEach(function(node) {
          if (node.x == null) return;
          var coords = Graph.graph2ScreenCoords(node.x, node.y, node.z);
          if (coords.x < -50 || coords.x > w + 50 || coords.y < -20 || coords.y > h + 20) return;
          ctx.strokeText(node.name, coords.x + 7, coords.y + 4);
          ctx.fillText(node.name, coords.x + 7, coords.y + 4);
        });
        requestAnimationFrame(renderLabels);
      }
      renderLabels();

      window.addEventListener('resize', function() {
        Graph.width(container.clientWidth).height(window.innerHeight);
      });
